# ─── GROQ API KEY ─────────────────────────────────────────────────
# Dapatkan GRATIS di: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── LANGSMITH (opsional, untuk monitoring) ───────────────────────
# Dapatkan GRATIS di: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Konfigurasi LangSmith ────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=asisten-pribadi-bahasa-indonesia
